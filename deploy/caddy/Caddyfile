controller.englishlisten.cn {
	encode zstd gzip

	handle /install.sh {
		root * /opt/sdwan/downloads
		file_server
	}

	handle /downloads/* {
		root * /opt/sdwan
		file_server
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:18080
	}

	handle /admin/* {
		reverse_proxy 127.0.0.1:18080
	}

	handle /healthz {
		reverse_proxy 127.0.0.1:18080
	}

	handle /readyz {
		reverse_proxy 127.0.0.1:18080
	}

	handle {
		reverse_proxy 127.0.0.1:8081
	}
}
